{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Mod",
      "type": "shell",
      "command": "nix --extra-experimental-features \"flakes nix-command\" develop --profile .nix-profile --command ./run",
      "problemMatcher": "$gcc",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "windows": {
        "command": "build.bat"
      }
    },
    {
      "label": "Open Star Rod",
      "type": "shell",
      "command": "nix --extra-experimental-features \"flakes nix-command\" develop --profile .nix-profile --command star-rod",
      "problemMatcher": [],
      "group": {
        "kind": "none"
      },
    },
    {
      "label": "Run Configure",
      "type": "shell",
      "command": "nix --extra-experimental-features \"flakes nix-command\" develop --profile .nix-profile --command ./configure",
      "problemMatcher": "$gcc",
      "group": {
        "kind": "none",
      },
      "windows": {
        "command": "build.bat"
      }
    },
    {
      "label": "Run Configure --clean",
      "type": "shell",
      "command": "nix --extra-experimental-features \"flakes nix-command\" develop --profile .nix-profile --command ./configure --clean",
      "problemMatcher": "$gcc",
      "group": {
        "kind": "none",
      },
      "windows": {
        "command": "build.bat"
      }
    },
  ]
}
